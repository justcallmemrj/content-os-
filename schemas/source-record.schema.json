{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "content-os/schemas/source-record@1.0.0",
  "title": "Source record frontmatter (Phase 3 §4.3)",
  "description": "projects/<id>/sources/S-*.md YAML frontmatter. cited_by is generated by index generation, not hand-maintained",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "publisher", "url", "type", "tier", "published", "effective", "accessed", "jurisdiction", "stability", "rights", "archived_copy", "status", "cited_by"],
  "properties": {
    "id": {"type": "string", "pattern": "^S-(BEN|DUC|TRD|FDR)-\\d{4}$"},
    "title": {"type": "string"},
    "publisher": {"type": "string"},
    "url": {"type": "string"},
    "type": {"type": "string", "enum": ["statute", "regulation", "agency-publication", "regulator-guidance", "peer-reviewed", "practitioner", "press", "dataset", "other"]},
    "tier": {"type": "integer", "minimum": 1, "maximum": 4},
    "published": {"type": "string"},
    "effective": {"type": "string"},
    "accessed": {"type": "string"},
    "jurisdiction": {"type": "string"},
    "stability": {"type": "string", "enum": ["static", "annual", "volatile"]},
    "rights": {"type": "string"},
    "archived_copy": {"anyOf": [{"type": "string"}, {"type": "null"}]},
    "status": {"type": "string", "enum": ["active", "superseded", "retired"]},
    "cited_by": {"type": "array", "items": {"type": "string", "pattern": "^F-(BEN|DUC|TRD|FDR)-\\d{4}$"}}
  }
}
