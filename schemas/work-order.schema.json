{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "content-os/schemas/work-order@1.0.0",
  "title": "Work order (Phase 5 §6.1)",
  "description": "runs/<id>/workorder.yaml — written at intake, immutable except state and appended human feedback",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "run_id", "parent_run", "project_id", "cross_project", "deliverable", "objective", "audience_ref", "funnel_stage", "voice_profile_version", "required_fact_ids", "disclosure_ids", "prohibited_notes", "asset_manifest_ref", "constraints", "model_tier_escalation", "state"],
  "properties": {
    "task_id": {"type": "string", "pattern": "^T-\\d{4}-\\d{4}-\\d{3}$"},
    "run_id": {"$ref": "#/$defs/runId"},
    "parent_run": {"anyOf": [{"$ref": "#/$defs/runId"}, {"type": "null"}]},
    "project_id": {"$ref": "#/$defs/projectId"},
    "cross_project": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["authorized_by", "second_project", "records_permitted", "reason"],
          "properties": {
            "authorized_by": {"type": "string"},
            "second_project": {"$ref": "#/$defs/projectId"},
            "records_permitted": {"type": "array", "items": {"type": "string"}, "minItems": 1},
            "reason": {"type": "string"}
          }
        }
      ]
    },
    "deliverable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "format", "platform", "spec"],
      "properties": {
        "type": {"type": "string"},
        "format": {"type": "string"},
        "platform": {"type": "string"},
        "spec": {"type": "string"}
      }
    },
    "objective": {"type": "string"},
    "audience_ref": {"type": "string"},
    "funnel_stage": {"type": "string"},
    "voice_profile_version": {"type": "string", "pattern": "^brand-voice\\.md@\\d+\\.\\d+\\.\\d+$"},
    "required_fact_ids": {"type": "array", "items": {"type": "string", "pattern": "^F-(BEN|DUC|TRD|FDR)-\\d{4}$"}},
    "disclosure_ids": {"type": "array", "items": {"type": "string", "pattern": "^DISC-(BEN|DUC|TRD|FDR)-"}},
    "prohibited_notes": {"type": "array", "items": {"type": "string"}},
    "asset_manifest_ref": {"anyOf": [{"type": "string"}, {"type": "null"}]},
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["length_words", "deadline"],
      "properties": {
        "length_words": {"type": "array", "items": {"type": "integer", "minimum": 0}, "minItems": 2, "maxItems": 2},
        "deadline": {"anyOf": [{"type": "string"}, {"type": "null"}]}
      }
    },
    "model_tier_escalation": {"type": "string"},
    "state": {
      "type": "string",
      "enum": ["requested", "intake", "context_loaded", "brief", "research", "draft", "fact_check", "revision", "voice_edit", "fact_delta", "compliance", "qa", "manager_review", "human_review", "approved", "done", "archived", "escalated",
               "storyboard", "engine_routing", "build", "preview_review", "render", "technical_qc", "judgment_qc", "delivery_ready", "human_signoff", "published", "performance_review"]
    },
    "calendar_ref": {"type": "string"},
    "parent_artifact_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "human_feedback": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "runId": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}-(ben|duc|trd|fdr)-[a-z0-9-]+-\\d{3}$"},
    "projectId": {"type": "string", "enum": ["benowitz-wealth", "ducat-private-wealth", "trading-research", "founder-brand"]}
  }
}
