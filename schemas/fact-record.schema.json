{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "content-os/schemas/fact-record@1.0.0",
  "title": "Approved fact record frontmatter (Phase 3 §4.2)",
  "description": "projects/<id>/approved-facts/F-*.md YAML frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "project", "claim_key", "statement", "topic", "source_ids", "source_type", "jurisdiction", "published", "effective", "accessed", "last_verified", "verified_by", "confidence", "status", "review_by", "supersedes", "superseded_by", "excerpt", "usage_notes", "approved_by", "approved_on", "sensitivity"],
  "properties": {
    "id": {"type": "string", "pattern": "^F-(BEN|DUC|TRD|FDR)-\\d{4}$"},
    "project": {"type": "string", "enum": ["benowitz-wealth", "ducat-private-wealth", "trading-research", "founder-brand"]},
    "claim_key": {"type": "string", "pattern": "^[a-z0-9-]+(\\.[a-z0-9-]+)+$"},
    "statement": {"type": "string"},
    "topic": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "source_ids": {"type": "array", "items": {"type": "string", "pattern": "^S-(BEN|DUC|TRD|FDR)-\\d{4}$"}, "minItems": 1},
    "source_type": {"type": "string", "enum": ["primary-agency", "statute", "regulation", "agency-publication", "regulator-guidance", "peer-reviewed", "practitioner", "press", "dataset", "other"]},
    "jurisdiction": {"type": "string"},
    "published": {"type": "string"},
    "effective": {"type": "string"},
    "accessed": {"type": "string"},
    "last_verified": {"type": "string"},
    "verified_by": {"type": "string"},
    "confidence": {"type": "string", "enum": ["low", "medium", "high"]},
    "status": {"type": "string", "enum": ["draft", "active", "superseded", "superseded-pending", "retired", "flagged-outdated", "quarantined"]},
    "review_by": {"type": "string"},
    "supersedes": {"anyOf": [{"type": "string", "pattern": "^F-(BEN|DUC|TRD|FDR)-\\d{4}$"}, {"type": "null"}]},
    "superseded_by": {"anyOf": [{"type": "string", "pattern": "^F-(BEN|DUC|TRD|FDR)-\\d{4}$"}, {"type": "null"}]},
    "excerpt": {"type": "string"},
    "usage_notes": {"type": "string"},
    "approved_by": {"type": "string"},
    "approved_on": {"type": "string"},
    "sensitivity": {"type": "string", "enum": ["S0", "S1", "S2"]}
  }
}
