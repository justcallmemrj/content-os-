# Default: normalize text line endings
* text=auto

# The ratified specifications are byte-stable for SHA-256 verification (D-078)
docs/architecture/** -text

# Git LFS: binary assets and renders (Phase 7 §3.1/§4; archive-out policy)
projects/*/assets/** filter=lfs diff=lfs merge=lfs -text
# ...except text records inside assets (scripts, captions, manifests) — reviewable in diffs
projects/*/assets/**/*.md !filter !diff !merge text=auto
projects/*/assets/**/*.txt !filter !diff !merge text=auto
projects/*/assets/**/*.yaml !filter !diff !merge text=auto
video/remotion/**/renders/** filter=lfs diff=lfs merge=lfs -text
video/hyperframes/**/renders/** filter=lfs diff=lfs merge=lfs -text
# ...except the manifest, which is the reviewable record (schema-validated)
video/*/**/renders/**/manifest.yaml !filter !diff !merge text=auto
video/remotion/**/previews/** filter=lfs diff=lfs merge=lfs -text
video/hyperframes/**/previews/** filter=lfs diff=lfs merge=lfs -text
archive/renders/** filter=lfs diff=lfs merge=lfs -text
